{
  "name": "chw-companion",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.1.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @chw/db migrate",
    "db:seed": "pnpm --filter @chw/db seed",
    "db:generate": "pnpm --filter @chw/db generate"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  }
}
